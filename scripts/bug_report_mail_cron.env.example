# Copy this file to bug_report_mail_cron.env (same directory) and fill in
# your server's real values. bug_report_mail_cron.env is gitignored, so it
# is safe to put real values there - it will never be committed.

PHP_BIN="/usr/local/bin/php"
ALERT_EMAIL="you@example.com"

# Optional: From address for alert emails. If left unset, sendmail picks
# its own default (usually the invoking system user @ this host).
#ALERT_FROM="mantis-cron@example.com"
